{
  "name": "sylo",
  "displayName": "Sylo",
  "description": "Re-entry briefs for humans. Context files for agents. No setup required.",
  "version": "0.1.0",
  "publisher": "sylo",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other", "AI"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sylo.showBrief",
        "title": "Sylo: Show re-entry brief"
      },
      {
        "command": "sylo.generateAgentContext",
        "title": "Sylo: Generate agent context file"
      },
      {
        "command": "sylo.openContextFile",
        "title": "Sylo: Open context file"
      },
      {
        "command": "sylo.clearHistory",
        "title": "Sylo: Clear snapshot history"
      }
    ],
    "keybindings": [
      {
        "command": "sylo.generateAgentContext",
        "key": "ctrl+shift+alt+s",
        "mac": "cmd+shift+alt+s"
      }
    ],
    "configuration": {
      "title": "Sylo",
      "properties": {
        "sylo.agentContextPath": {
          "type": "string",
          "default": "SYLO_CONTEXT.md",
          "description": "Output path relative to workspace root. Set to CLAUDE.md to feed Claude Code directly."
        },
        "sylo.awayThresholdMinutes": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 60,
          "description": "Minutes away before re-entry brief triggers"
        },
        "sylo.autoShow": {
          "type": "boolean",
          "default": true,
          "description": "Show brief notification when you return to VS Code"
        },
        "sylo.apiBaseUrl": {
          "type": "string",
          "default": "https://api.sylo.dev",
          "description": "Sylo API URL. Only change this if you are self-hosting the Sylo server."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sylo",
          "title": "Sylo",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "sylo": [
        {
          "type": "webview",
          "id": "sylo.panel",
          "name": "Context"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "sylo.generateAgentContext",
          "group": "sylo@1"
        }
      ]
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --target=node18",
    "watch": "npm run build -- --watch",
    "package": "vsce package",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.24.0"
  },
  "dependencies": {}
}
