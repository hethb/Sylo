{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "cd packages/api && npm install && npm run build"
  },
  "deploy": {
    "startCommand": "cd packages/api && npm run start",
    "healthcheckPath": "/health",
    "restartPolicyType": "on_failure"
  }
}
